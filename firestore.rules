rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Firebase Auth UID)
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - displayName: string (required) - User's display name
    //   - email: string (required) - User's email address
    //   - photoURL: string (optional) - User's profile picture URL
    //   - status: string (optional, enum: ['online', 'offline']) - Current online status
    //   - lastSeen: string (optional, ISO 8601) - Last time the user was active
    //
    // Collection: messages
    // Document ID: {messageId} (auto-generated)
    // Fields:
    //   - senderId: string (required, immutable) - UID of the sender
    //   - receiverId: string (required, immutable) - UID of the receiver
    //   - text: string (required, max 5000 chars) - Content of the message
    //   - timestamp: timestamp (required, immutable) - When the message was sent
    //   - read: boolean (optional) - Whether the message has been read
    //
    // Collection: notifications
    // Document ID: {notificationId} (auto-generated)
    // Fields:
    //   - userId: string (required) - UID of the recipient
    //   - title: string (required) - Notification title
    //   - body: string (required) - Notification body
    //   - status: string (required, enum: ['pending', 'delivered']) - Delivery status
    //   - timestamp: timestamp (required) - When the notification was created
    //   - data: map (optional) - Additional payload
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "tanbirahmedkhan75@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('username' in data) || (data.username is string && data.username.size() >= 3 && data.username.size() < 30)) &&
             data.email is string && data.email.size() > 0 &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 2000)) &&
             (!('status' in data) || (data.status in ['active', 'offline', 'away', 'transmitting', 'online'])) &&
             (!('lastSeen' in data) || (data.lastSeen is timestamp || data.lastSeen is string)) &&
             (!('blockedUsers' in data) || (data.blockedUsers is list)) &&
             (!('friends' in data) || (data.friends is list)) &&
             (!('friendRequests' in data) || (data.friendRequests is list)) &&
             (!('pinnedChats' in data) || (data.pinnedChats is list)) &&
             (!('mutedChats' in data) || (data.mutedChats is list)) &&
             (!('lockedChats' in data) || (data.lockedChats is list)) &&
             (!('starredMessages' in data) || (data.starredMessages is list)) &&
             (!('settings' in data) || (data.settings is map)) &&
             (!('bio' in data) || (data.bio is string)) &&
             (!('address' in data) || (data.address is string)) &&
             (!('dob' in data) || (data.dob is string)) &&
             (!('otherInfo' in data) || (data.otherInfo is string)) &&
             (!('showOnlineStatus' in data) || (data.showOnlineStatus is bool)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt is string)) &&
             (!('role' in data) || (data.role is string && data.role in ['user', 'admin']));
    }

    function isRoleUnchanged() {
      return request.resource.data.get('role', 'user') == resource.data.get('role', 'user');
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'text', 'timestamp', 'chatId', 'participants']) &&
             data.senderId is string && (data.senderId == request.auth.uid || data.senderId == "ai-assistant" || data.senderId == "system") &&
             data.receiverId is string && data.receiverId.size() > 0 &&
             data.text is string && data.text.size() < 10000 && 
             (data.timestamp is timestamp || data.timestamp == request.time) &&
             data.chatId is string &&
             data.participants is list && data.participants.size() >= 2 &&
             (request.auth.uid in data.participants || data.senderId == "ai-assistant" || data.senderId == "system") &&
             (!('read' in data) || (data.read is bool)) &&
             (!('isAI' in data) || (data.isAI is bool)) &&
             (!('fileUrl' in data) || (data.fileUrl is string)) &&
             (!('fileName' in data) || (data.fileName is string)) &&
             (!('fileType' in data) || (data.fileType is string)) &&
             (!('voiceUrl' in data) || (data.voiceUrl is string)) &&
             (!('isDeleted' in data) || (data.isDeleted is bool)) &&
             (!('isGroup' in data) || (data.isGroup is bool)) &&
             (!('reactions' in data) || (data.reactions is list)) &&
             (!('deletedFor' in data) || (data.deletedFor is list)) &&
             (!('forwardedFrom' in data) || (data.forwardedFrom is string)) &&
             (!('isEdited' in data) || (data.isEdited is bool)) &&
             (!('isEncrypted' in data) || (data.isEncrypted is bool)) &&
             (!('disappearingAt' in data) || data.disappearingAt == null || data.disappearingAt is timestamp) &&
             (!('typingStartedAt' in data) || data.typingStartedAt == null || data.typingStartedAt is timestamp) &&
             (!('location' in data) || (data.location is map)) &&
             (!('contact' in data) || (data.contact is map)) &&
             (!('pinned' in data) || (data.pinned is bool)) &&
             (!('isEmergency' in data) || (data.isEmergency is bool));
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'createdBy', 'members', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdBy is string &&
             data.members is list && data.members.size() >= 1 &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('admins' in data) || (data.admins is list)) &&
             (!('photoURL' in data) || (data.photoURL is string)) &&
             (!('bio' in data) || (data.bio is string)) &&
             (!('description' in data) || (data.description is string)) &&
             (!('rules' in data) || (data.rules is string)) &&
             (!('settings' in data) || (data.settings is map)) &&
             (!('inviteLink' in data) || (data.inviteLink is string)) &&
             (!('pendingMembers' in data) || (data.pendingMembers is list)) &&
             (!('lastMessage' in data) || (data.lastMessage is string)) &&
             (!('lastMessageTime' in data) || (data.lastMessageTime is timestamp || data.lastMessageTime == request.time));
    }

    function isGroupAdmin(groupData) {
      return isAuthenticated() && (
        (groupData.admins is list && request.auth.uid in groupData.admins) || 
        groupData.createdBy == request.auth.uid
      );
    }

    function isValidStatus(data) {
      return data.keys().hasAll(['uid', 'displayName', 'type', 'content', 'expiresAt', 'createdAt', 'visibility']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 2000)) &&
             data.type in ['image', 'video', 'text', 'voice'] &&
             data.content is string && data.content.size() < 10485760 && // 10MB limit for base64
             data.expiresAt is timestamp &&
             data.createdAt is timestamp &&
             data.visibility in ['all_contacts', 'custom'] &&
             (!('visibleTo' in data) || data.visibleTo is list) &&
             (!('caption' in data) || data.caption is string) &&
             (!('duration' in data) || data.duration is number) &&
             (!('likes' in data) || data.likes is list) &&
             (!('dislikes' in data) || data.dislikes is list) &&
             (!('views' in data) || data.views is list) &&
             (!('replies' in data) || data.replies is list);
    }

    function isValidCall(data) {
      return data.keys().hasAll(['callerId', 'receiverId', 'participants', 'type', 'status', 'startTime', 'endTime', 'duration']) &&
             data.callerId is string && data.receiverId is string &&
             data.participants is list && data.participants.size() == 2 &&
             (request.auth.uid in data.participants) &&
             data.type in ['audio', 'video'] &&
             data.status in ['completed', 'missed', 'rejected'] &&
             (data.startTime is timestamp || data.startTime == request.time) &&
             (data.endTime is timestamp || data.endTime == request.time) &&
             data.duration is number &&
             (!('callerName' in data) || data.callerName is string) &&
             (!('callerPhoto' in data) || data.callerPhoto is string) &&
             (!('receiverName' in data) || data.receiverName is string) &&
             (!('receiverPhoto' in data) || data.receiverPhoto is string);
    }

    function isValidRTSPFeed(data) {
      return data.keys().hasAll(['name', 'url', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.url is string && data.url.size() > 0 && data.url.size() < 1000 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'body', 'status', 'timestamp']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.body is string && data.body.size() > 0 && data.body.size() < 1000 &&
             data.status in ['pending', 'delivered'] &&
             (data.timestamp is timestamp || data.timestamp == request.time) &&
             (!('data' in data) || data.data is map);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /statuses/{statusId} {
      allow list: if isAuthenticated();
      allow get: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        resource.data.visibility == 'all_contacts' ||
        (resource.data.visibility == 'custom' && request.auth.uid in resource.data.visibleTo) ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidStatus(request.resource.data);
      allow update: if isAuthenticated() && (
                      (request.auth.uid == resource.data.uid && isValidStatus(request.resource.data)) || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes', 'replies', 'views'])) ||
                      isAdmin()
                    );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin() || resource.data.expiresAt <= request.time);
    }

    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.get('role', 'user') == 'user' || isAdmin());
      allow update: if isAuthenticated() && (
                      (isOwner(userId) && isValidUser(request.resource.data) && (isRoleUnchanged() || isAdmin())) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendRequests']) && 
                       request.auth.uid in request.resource.data.friendRequests &&
                       request.resource.data.friendRequests.hasAll(resource.data.get('friendRequests', []))) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) && 
                       request.auth.uid in request.resource.data.friends &&
                       request.resource.data.friends.hasAll(resource.data.get('friends', []))) ||
                      isAdmin()
                    );
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read, list: if isAuthenticated() && (request.auth.uid in resource.data.members || isAdmin() || resource.data.get('inviteLink', '') != '');
      allow create: if isAuthenticated() && isValidGroup(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (
                      isGroupAdmin(resource.data) || 
                      (resource.data.get('settings', {}).get('editGroupInfo', 'all') == 'all' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'photoURL'])) ||
                      (request.resource.data.members.size() != resource.data.members.size() && (request.auth.uid in request.resource.data.members || request.auth.uid in resource.data.members)) || // Joining/Leaving
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers'])) || // Requesting to join
                      isAdmin()
                    ) && isValidGroup(request.resource.data);
      allow delete: if isAuthenticated() && (isGroupAdmin(resource.data) || isAdmin());
    }

    match /messages/{messageId} {
      allow read, list: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin()) && (
                      // Anyone in participants can update read status, reactions, pinned, or deletedFor
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'reactions', 'deletedFor', 'pinned'])) ||
                      // Only sender can edit text or mark as deleted for everyone
                      ((request.auth.uid == resource.data.senderId || isAdmin()) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'text', 'isEdited', 'fileUrl', 'fileName', 'fileType']))
                    ) &&
                    (request.resource.data.senderId == resource.data.senderId) &&
                    (request.resource.data.receiverId == resource.data.receiverId) &&
                    (request.resource.data.chatId == resource.data.chatId);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.senderId || isAdmin());
    }

    match /calls/{callId} {
      allow read, list: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && isValidCall(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin()) && isValidCall(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
    }

    match /rtsp_feeds/{feedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRTSPFeed(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin()) && isValidRTSPFeed(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read, list: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
